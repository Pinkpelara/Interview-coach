# Database - PostgreSQL (Neon, Supabase, or Railway)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="https://your-app.vercel.app"

# OpenRouter AI Gateway (V5 spec section 6)
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY="your-openrouter-api-key-here"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# Optional: separate key for development
# OPENROUTER_API_KEY_DEV="your-dev-key"

# Redis (for request queue and caching - optional for MVP)
# REDIS_URL="redis://localhost:6379"
