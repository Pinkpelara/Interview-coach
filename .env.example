# Database - Use a PostgreSQL provider (Neon, Supabase, or Railway)
# Neon free tier: https://neon.tech (recommended for Vercel)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="https://your-app.vercel.app"

# AI Service (OpenAI-compatible, server-side only)
# Point this to your self-hosted gateway/model server for production.
AI_PRIMARY_BASE_URL="http://localhost:8000/v1"
AI_PRIMARY_API_KEY="server-side-secret-only"
AI_PRIMARY_CHAT_MODEL="gpt-4.1-nano"
AI_PRIMARY_TTS_MODEL="gpt-4o-mini-tts"
AI_PRIMARY_TIMEOUT_MS="12000"

# Optional fallback provider (used only if primary fails)
# AI_FALLBACK_BASE_URL="http://localhost:8001/v1"
# AI_FALLBACK_API_KEY="server-side-fallback-secret"
# AI_FALLBACK_CHAT_MODEL="gpt-4.1-nano"
# AI_FALLBACK_TTS_MODEL="gpt-4o-mini-tts"
# AI_FALLBACK_TIMEOUT_MS="12000"

# Integration hardening controls
AI_MAX_RETRIES="2"
AI_MAX_INPUT_CHARS="12000"
AI_PROMPT_VERSION="v1"

# Optional real-time conductor orchestration (Phase C architecture)
# INTERVIEW_CONDUCTOR_URL="http://localhost:8091"

# Optional WebSocket media relay for interview exchange transport (frontend)
# NEXT_PUBLIC_INTERVIEW_WS_URL="ws://localhost:8787/ws/interview"

# Browser TTS fallback is disabled by default to avoid robotic voices.
# Enable only for local testing when server TTS is unavailable.
NEXT_PUBLIC_ALLOW_BROWSER_TTS_FALLBACK="false"

# Optional health orchestration URLs (used by /api/health/orchestration)
# MEDIA_RELAY_HEALTH_URL="http://localhost:8787/healthz"
# INTERVIEW_CONDUCTOR_HEALTH_URL="http://localhost:8091/healthz"
# GPU_WORKERS_HEALTH_URL="http://localhost:8092/healthz"
# AI_ENGINE_HEALTH_URL="http://localhost:8093/healthz"
# API_SERVER_HEALTH_URL="http://localhost:8094/healthz"

# Legacy compatibility bridge (supported temporarily):
# If AI_PRIMARY_* are not set but PUTER_API_TOKEN is present,
# the app will auto-enable legacy mode to avoid breaking older deployments.
# PUTER_API_TOKEN="legacy-token"
# PUTER_AI_MODEL="gpt-4.1-nano"

# Optional persistent rate limiting (Upstash Redis REST)
# UPSTASH_REDIS_REST_URL="https://<your-instance>.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="<upstash-token>"

# Optional alerting webhook for degraded health / AI provider outages
# ALERT_WEBHOOK_URL="https://hooks.slack.com/services/..."
# ALERT_COOLDOWN_MS="300000"

# Optional email notification delivery webhook (platform-controlled mail worker)
# NOTIFICATION_EMAIL_WEBHOOK_URL="https://your-mail-worker.internal/send"
# Optional auth token for scheduled notification dispatch endpoint
# NOTIFICATION_DISPATCH_TOKEN="replace-with-strong-random-token"
